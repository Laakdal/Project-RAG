    },
    {
      "id": "2cdcc8a4-b3df-414b-ba71-26d30c310410",
      "name": "Post Index",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1560,
        420
      ],
      "parameters": {
        "method": "POST",
        "url": "http://rag_backend:4000/library/index-drive",
        "sendHeaders": true,
        "specifyHeaders": "keypair",
        "headerParameters": {
          "parameters": [
            {
              "name": "x-index-token",
              "value": "__REDACTED_LIBRARY_INDEX_TOKEN__"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={\n  \"driveFileId\": {{ JSON.stringify($('Next File').first().json.driveFileId) }},\n  \"filename\": {{ JSON.stringify($('Next File').first().json.filename) }},\n  \"text\": {{ JSON.stringify(($json.text || \"\")) }}\n}",
        "options": {
          "timeout": 120000,
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      }
    },
