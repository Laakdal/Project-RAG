      "id": "fa31479b-1c26-40c9-a86e-5cd025c0b00d",
      "name": "Gotenberg Convert",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [
        128,
        208
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000,
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "const items=$input.all();const out=[];for(let i=0;i<items.length;i++){const buffer=await this.helpers.getBinaryDataBuffer(i,'file0');const bin=(items[i].binary&&items[i].binary.file0)||{};out.push({json:{base64:buffer.toString('base64'),fileName:bin.fileName||'document'},binary:items[i].binary,pairedItem:{item:i}});}return out;"
      },
      "id": "f9d3bb42-b53a-4f08-9186-98a325e9234e",
      "name": "PDF To Base64",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        352,
        304
      ]
    },
    {
      "parameters": {
        "jsCode": "const items=$input.all();const out=[];for(let i=0;i<items.length;i++){const buffer=await this.helpers.getBinaryDataBuffer(i,'file0');const bin=(items[i].binary&&items[i].binary.file0)||{};out.push({json:{base64:buffer.toString('base64'),fileName:bin.fileName||'document',mimeType:bin.mimeType||'image/png'},binary:items[i].binary,pairedItem:{item:i}});}return out;"
      },
      "id": "93521d5a-2f26-4bce-9278-453e1956aef9",
      "name": "Image To Base64",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        352,
        512
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "openRouterApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{\n  JSON.stringify({\n    model: ($('Reader Trigger').first().json.model || \"google/gemini-2.5-pro\"),\n    temperature: 0,\n    max_tokens: 16384,\n    messages: [{\n      role: \"user\",\n      content: [\n        {\n          type: \"text\",\n          text: `Transcribe this image's entire contents into Markdown, verbatim and completely.\nYou MUST read and transcribe the actual text INSIDE the image, exactly as shown.\nDo NOT output image placeholders; write what the image actually contains.\nPut code or terminal text in fenced code blocks and render tables as Markdown tables.\nNever pad with spaces or emit blank or whitespace-only lines, and never repeat a character to fill space; use single spaces and at most one blank line between blocks.\nMark unreadable text as [illegible].\nFor purely decorative graphics with no text, add a brief [Figure: ...] note.\nOutput only the transcription, nothing else.`\n        },\n        {\n          type: \"image_url\",\n          image_url: {\n            url: \"data:\" + $json.mimeType + \";base64,\" + $json.base64\n          }\n        }\n      ]\n    }]\n  })\n}}",
        "options": {
          "timeout": 60000
        }
      },
      "id": "08c92e71-8192-45ef-bdf3-25ec09e2bacb",
      "name": "Read Image",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [
        560,
        512
      ],
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 2000,
      "credentials": {
        "openRouterApi": {
          "id": "MZvZzDvDMnbBgoUs",
          "name": "OpenRouter account"
        }
      },
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "const j = $input.first().json || {};\nlet text = (j.choices && j.choices[0] && j.choices[0].message && j.choices[0].message.content)\n  || j.text || j.data || '';\n// Defensive: a VLM transcribing padded editor/terminal screenshots can fall into a\n// degenerate character-repetition loop (runaway spaces, dashes, '=', etc.) that bloats\n// or truncates the document. Strip trailing space and collapse any non-newline char\n// repeated 20+ times down to 20, plus squeeze excessive blank lines, so one screenshot\n// can't derail the read. The real content survives; only degenerate runs are clipped.\ntext = String(text || '')\n  .replace(/[ \\t]+$/gm, '')\n  .replace(/([^\\n])\\1{19,}/g, (m, c) => c.repeat(20))\n  .replace(/\\n{4,}/g, '\\n\\n');\nreturn [{ json: { text } }];"
      },
      "id": "e7dabf1d-54a0-4408-bde3-b853f26cffcf",
      "name": "Reader Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1360,
        496
      ]
    },
    {
      "parameters": {
        "operation": "text",
        "binaryPropertyName": "file0",
        "options": {}
      },
      "id": "5ae01008-e261-4407-8c8b-b7aefa9ab66c",
      "name": "Extract Text",
      "type": "n8n-nodes-base.extractFromFile",
      "typeVersion": 1.1,
      "position": [
        352,
        688
      ]
    },
    {
      "parameters": {
        "operation": "xlsx",
        "binaryPropertyName": "file0",
        "options": {}
      },
      "id": "51c60f2c-6f93-49fe-ada4-5ccdcff15a0d",
      "name": "Extract XLSX",
      "type": "n8n-nodes-base.extractFromFile",
      "typeVersion": 1.1,
      "position": [
        352,
        864
      ]
    },
    {
      "parameters": {
        "jsCode": "const rows = $input.all().map(i => i.json);\nconst sheets = {};\nfor (const row of rows) {\n  const sheet = row['__sheet'] || 'Sheet1';\n  if (!sheets[sheet]) sheets[sheet] = [];\n  sheets[sheet].push(row);\n}\nconst text = Object.entries(sheets).map(([sheetName, sheetRows]) => {\n  const rowText = sheetRows.map(r => \n    Object.entries(r)\n      .filter(([k]) => k !== '__sheet')\n      .map(([k, v]) => k + ': ' + v)\n      .join(' | ')\n  ).join('\\n');\n  return `## Sheet: ${sheetName}\\n${rowText}`;\n}).join('\\n\\n');\nreturn [{ json: { text }, pairedItem: { item: 0 } }];"
      },
      "id": "b22e97b1-79c5-418b-aa4a-a2fdb071b97f",
      "name": "Stringify XLSX",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        560,
        864
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "openRouterApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{\n  JSON.stringify({\n    model: ($('Reader Trigger').first().json.model || \"google/gemini-2.5-pro\"),\n    temperature: 0,\n    max_tokens: 16384,\n    plugins: [{\n      id: \"file-parser\",\n      pdf: { engine: \"native\" }\n    }],\n    messages: [{\n      role: \"user\",\n      content: [\n        {\n          type: \"text\",\n          text: `Transcribe this document's entire contents into Markdown, verbatim and completely, from the FIRST page through the LAST page. Transcribe every page in order; never stop early, summarize, or skip pages.\nPages or images may include screenshots (e.g. of code, terminal output, editor windows, tables) — you MUST read and transcribe the actual text INSIDE those images, exactly as shown.\nDo NOT output image placeholders; write what each image actually contains.\nPut code or terminal text in fenced code blocks and render tables as Markdown tables.\nNever pad with spaces or emit blank or whitespace-only lines, and never repeat a character to fill space; use single spaces and at most one blank line between blocks.\nMark unreadable text as [illegible].\nFor purely decorative graphics with no text, add a brief [Figure: ...] note.\nOutput only the transcription, nothing else.`\n        },\n        {\n          type: \"file\",\n          file: {\n            filename: $json.fileName,\n            file_data: \"data:application/pdf;base64,\" + $json.base64\n          }\n        }\n      ]\n    }]\n  })\n}}",
        "options": {
          "timeout": 60000
        }
      },
      "id": "ae5de5fc-83a0-489e-bdbc-2a9b329f61b5",
      "name": "Read PDF",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [
        560,
        304
      ],
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 2000,
      "credentials": {
        "openRouterApi": {
          "id": "MZvZzDvDMnbBgoUs",
          "name": "OpenRouter account"
        }
      },
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "// Read PDF's error output drops the binary, so re-attach the PDF bytes that\n// went into the reader (the original PDF, or the Gotenberg-converted PDF for\n// Office files) so the text-layer fallback below can read file0.\nreturn [{ json: {}, binary: $('PDF To Base64').first().binary }];"
      },
      "id": "82547169-ff3d-4a90-85e7-708da5e4b2dd",
      "name": "Restore PDF Binary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
