        "options": {}
      },
      "id": "e5c8a088-979b-4bd6-9aca-d0e594d02eab",
      "name": "Extract PDF Fallback",
      "type": "n8n-nodes-base.extractFromFile",
      "typeVersion": 1.1,
      "position": [
        1040,
        304
      ],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// Graceful skip: the read/convert failed and there is no text layer to fall\n// back to (a failed image read, or an Office file when Gotenberg is down), so\n// emit empty text. Ingest then completes with 0 chunks instead of hard-failing.\nreturn [{ json: { text: '' } }];"
      },
      "id": "6509011c-0eaa-46c0-9ad3-d72747b6734c",
      "name": "Empty Text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        800,
        464
      ]
    }
