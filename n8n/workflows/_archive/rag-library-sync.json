    {
      "parameters": {
        "jsCode": "const SUPPORTED = ['pdf','docx','pptx','xlsx','png','jpg','jpeg','webp','txt','md','csv','json'];\nfunction readable(file) {\n  const mt = file.mimeType || '';\n  // Google Docs/Sheets/Slides get converted on download → readable\n  if (mt.startsWith('application/vnd.google-apps.')) return mt !== 'application/vnd.google-apps.folder';\n  const ext = ((file.name || '').split('.').pop() || '').toLowerCase();\n  return SUPPORTED.includes(ext);\n}\nconst inputs = $input.all();\nconst files = $('List Account Files').all();\nconst out = [];\nfor (let i = 0; i < inputs.length; i++) {\n  const res = inputs[i].json;\n  const file = files[i].json;\n  const points = (res && res.result && res.result.points) || [];\n  const storedMtime = points[0] && points[0].payload && points[0].payload.metadata && points[0].payload.metadata.modifiedTime;\n  const needsSync = readable(file) && (points.length === 0 || storedMtime !== file.modifiedTime);\n  out.push({ json: { id: file.id, name: file.name, mimeType: file.mimeType, modifiedTime: file.modifiedTime, needsSync } });\n}\nreturn out;"
      },
      "id": "002b8d19-78b6-4970-bb24-ac0a50b6153b",
      "name": "Decide Sync",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
