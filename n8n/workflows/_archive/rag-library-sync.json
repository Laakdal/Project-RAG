              "leftValue": "={{ $json.needsSync }}",
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              },
              "rightValue": ""
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "5080b1f8-af3b-4ba5-b217-1095cbb3677a",
      "name": "Needs Sync?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        800,
        304
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst out = [];\nfor (let i = 0; i < items.length; i++) {\n  const bin = (items[i].binary && items[i].binary.file0) || {};\n  const meta = $('Decide Sync').item.json;\n  const fileName = bin.fileName || meta.name || 'document';\n  const ext = (bin.fileExtension || (fileName.split('.').pop() || '')).toLowerCase();\n  out.push({ json: { filename: fileName, ext, driveFileId: meta.id, modifiedTime: meta.modifiedTime }, binary: items[i].binary, pairedItem: { item: i } });\n}\nreturn out;"
      },
