# Copy to `.env.vps` on the VPS and fill in real values:
#   cp .env.vps.example .env.vps
# Then: docker compose -f docker-compose.vps.yml --env-file .env.vps up -d --build

# --- Postgres (private to the VPS Docker network) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=project_rag

# --- Backend ---
# REQUIRED. Generate with: openssl rand -hex 32
SESSION_SECRET=

# Browser origin of your local frontend (what calls the API).
CORS_ORIGIN=http://localhost:3000

# --- Admin user (auto-seeded on `up`, idempotent). Email MUST have a TLD. ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-to-a-strong-password
ADMIN_NAME=Admin

# --- n8n location (used by the RAG chat path) ---
# Default instance for all webhooks (rag-query, rag-ingest, rag-read).
N8N_BASE_URL=https://n8n.ariorafa.site
# Optional override for JUST the Read Document (rag-read) webhook. Set this to
# stage the read workflow on a second n8n instance while query/ingest stay on
# N8N_BASE_URL. Leave unset once everything lives on one instance.
N8N_READ_URL=https://n8n.anxietypha.my.id
