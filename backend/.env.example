# Postgres connection string
DATABASE_URL=postgres://user:password@localhost:5432/project_rag

# Secret used to sign the session cookie (use a long random value)
SESSION_SECRET=change-me-to-a-long-random-secret

# Port the HTTP server listens on
PORT=4000

# Node environment: development | production | test
NODE_ENV=development

# Set to true only when serving over HTTPS (production)
COOKIE_SECURE=false

# Session cookie SameSite policy: lax | strict | none
# Use "none" (requires COOKIE_SECURE=true) for a genuinely cross-site SPA;
# use "strict"/"lax" when the frontend and API share a registrable domain.
COOKIE_SAMESITE=lax

# Allowed cross-origin (the frontend origin)
CORS_ORIGIN=http://localhost:3000
