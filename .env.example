# Root stack config for docker-compose.yml. Copy to `.env` and adjust.
#   cp .env.example .env

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=project_rag

# --- Backend ---
# Long random value used to sign the session cookie.
SESSION_SECRET=change-me-to-a-long-random-secret

# --- Admin user (auto-seeded on `docker compose up`, idempotent) ---
# Must be a full email with a TLD — the backend's validator rejects bare hosts like admin@local.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123
ADMIN_NAME=Admin
